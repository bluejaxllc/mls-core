# --- Backend Production Environment Variables ---

# Server
PORT=3001
NODE_ENV=production

# Database (Prisma)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=public
DATABASE_URL=

# Blue Jax Integration
# The API Token for interacting with Blue Jax / GHL APIs
BLUE_JAX_API_TOKEN=
# The Agency Key for high-level operations
BLUE_JAX_AGENCY_KEY=
# The Public Key or Shared Secret used to verify JWTs from Blue Jax
BLUE_JAX_PUBLIC_KEY=

# Security
# Secret used to verify webhook payloads from Blue Jax
WEBHOOK_SECRET=
