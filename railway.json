{
    "$schema": "https://railway.app/railway.schema.json",
    "build": {
        "builder": "NIXPACKS",
        "watchPatterns": ["web/**"],
        "buildCommand": "cd web && npm install && npm run build",
        "nixpacksPlan": {
            "providers": ["node"]
        }
    },
    "deploy": {
        "startCommand": "cd web && npm start",
        "healthcheckPath": "/health",
        "restartPolicyType": "ON_FAILURE",
        "healthcheckTimeout": 120
    }
}